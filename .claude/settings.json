{
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": [
      "/tmp"
    ],
    "allow": [
      "Bash(npx tsc --noEmit *)",
      "Bash(npx tsc --noEmit)",
      "Bash(npm test *)",
      "Bash(npm test)",
      "Bash(npm run typecheck *)",
      "Bash(npm run typecheck)",
      "Bash(npm run build *)",
      "Bash(npx vitest run *)",
      "Bash(npx vitest run)",
      "Bash(npx pnpm --filter * test *)",
      "Bash(npx pnpm --filter * build *)",
      "Bash(npx pnpm --filter * typecheck *)",
      "Bash(npx pnpm typecheck *)",
      "Bash(npx pnpm test *)",
      "Bash(npx playwright test *)",
      "Bash(npm run build)",
      "Bash(curl *)",
      "Bash(lsof *)",
      "Bash(kill *)",
      "Bash(pgrep *)",
      "Bash(ps *)",
      "Bash(pkill *)",
      "Bash(sed *)",
      "Bash(grep *)",
      "Read(/tmp/**)",
      "Bash(sed -n * /tmp/wrangler-build*/index.js)",
      "Bash(sed -n * /tmp/wrangler-build*/index.js > /tmp/*.js)",
      "Bash(wc -l /tmp/*.js)",
      "Bash(grep -n * /tmp/wrangler-build*/index.js)",
      "Bash(grep -n * /tmp/wrangler-build*/index.js | head -*)",
      "Bash(head -n * /tmp/*.js)",
      "Bash(tail -n * /tmp/*.js)"
    ]
  }
}
