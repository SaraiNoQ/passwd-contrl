# Legacy Fastify API (optional fallback)
DATABASE_URL=                          # Optional: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public. Leave empty for MemoryVaultStore (dev only)
API_PORT=4000                          # Legacy API server port
WEB_ORIGIN=http://localhost:3000       # Legacy API CORS origin
MAINTENANCE_TOKEN=                     # Optional: token for maintenance endpoints

# Web App
NEXT_PUBLIC_API_URL=http://localhost:8787  # Local Cloudflare Worker API URL
NEXT_PUBLIC_EXTENSION_ID=              # Optional: Chrome extension ID for bridge

# Cloudflare Worker API local development
CORS_ORIGIN=*                          # Hono echoes concrete Origin when credentials are enabled.
SESSION_SECRET=dev-session-secret-replace-in-production

# OPAQUE (optional, auto-generated if empty)
OPAQUE_SERVER_SETUP=

# Production Only (do not set for local development)
# SECURE_COOKIES=true
# CORS_ORIGINS=https://vault.example.com
# LOG_LEVEL=warn
