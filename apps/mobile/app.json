{
  "expo": {
    "name": "Zero Vault",
    "slug": "zero-vault",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "zero-vault",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#050B12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zerovault.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050B12"
      },
      "package": "com.zerovault.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite"
    ]
  }
}
