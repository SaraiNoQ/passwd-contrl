{
  "name": "zero-vault",
  "version": "0.1.0",
  "private": true,
  "description": "Zero-knowledge password vault with web, browser extension, and future mobile clients.",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm run dev:worker & pnpm run dev:web",
    "dev:worker": "pnpm --filter @zero-vault/worker-api dev",
    "dev:web": "pnpm --filter @zero-vault/web dev",
    "dev:desktop": "pnpm run dev:worker & ZERO_VAULT_API_URL=http://localhost:8787 pnpm --dir apps/desktop exec tauri dev",
    "dev:extension": "pnpm --filter @zero-vault/extension dev",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter @zero-vault/extension test:e2e && pnpm --filter @zero-vault/web test:e2e",
    "test:e2e:sync": "pnpm --filter @zero-vault/web test:e2e:sync",
    "test:rust": "cargo test --manifest-path crates/crypto-core/Cargo.toml",
    "test:all": "pnpm test && pnpm test:rust",
    "typecheck": "pnpm -r --if-present typecheck",
    "wasm:build": "wasm-pack build crates/crypto-core --target web --out-dir ../../packages/crypto-core-wasm/pkg",
    "audit": "npx pnpm audit && cargo audit --file crates/crypto-core/Cargo.toml"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
